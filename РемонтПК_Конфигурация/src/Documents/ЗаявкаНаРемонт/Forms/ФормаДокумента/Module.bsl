&НаКлиенте
Процедура СпециалистПриИзменении(Элемент)
	ПроверитьГрафикСпециалиста();
КонецПроцедуры

&НаКлиенте
Процедура ДатаВыполненияПриИзменении(Элемент)
	ПроверитьГрафикСпециалиста();
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьГрафикСпециалиста()
	Если НЕ ЗначениеЗаполнено(Объект.Специалист) 
		ИЛИ НЕ ЗначениеЗаполнено(Объект.ДатаВыполнения) Тогда
		Возврат;
	КонецЕсли;
	
	РезультатПроверки = ПроверитьГрафикНаСервере(
		Объект.Специалист, Объект.ДатаВыполнения);
	
	Если НЕ РезультатПроверки Тогда
		Сообщить("Внимание: специалист " + Объект.Специалист 
			+ " не работает в выбранный день!");
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ПроверитьГрафикНаСервере(Специалист, ДатаВыполнения)
	
	// Определяем день недели из даты (1=Пн, 2=Вт, ... 7=Вс)
	НомерДня = ДеньНедели(ДатаВыполнения);
	
	// Получаем соответствующее значение перечисления
	ДеньПеречисления = ПолучитьДеньПеречисления(НомерДня);
	
	// Проверяем есть ли этот день в графике специалиста
	ДанныеСпециалиста = Специалист.ПолучитьОбъект();
	
	Для Каждого Строка Из ДанныеСпециалиста.График Цикл
		Если Строка.ДеньНедели = ДеньПеречисления Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаСервере
Функция ПолучитьДеньПеречисления(НомерДня)
	Дни = Перечисления.ДниНедели;
	Если    НомерДня = 1 Тогда Возврат Дни.Понедельник;
	ИначеЕсли НомерДня = 2 Тогда Возврат Дни.Вторник;
	ИначеЕсли НомерДня = 3 Тогда Возврат Дни.Среда;
	ИначеЕсли НомерДня = 4 Тогда Возврат Дни.Четверг;
	ИначеЕсли НомерДня = 5 Тогда Возврат Дни.Пятница;
	ИначеЕсли НомерДня = 6 Тогда Возврат Дни.Суббота;
	ИначеЕсли НомерДня = 7 Тогда Возврат Дни.Восресенье;
	КонецЕсли;
КонецФункции