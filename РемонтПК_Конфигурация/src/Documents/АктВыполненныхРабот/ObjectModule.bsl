Процедура ОбработкаПроведения(Отказ, Режим)
		
	// Получаем специалиста
	СпециалистДляРегистра = Специалист;
	Если НЕ ЗначениеЗаполнено(СпециалистДляРегистра) 
		И ЗначениеЗаполнено(Заявка) Тогда
		СпециалистДляРегистра = Заявка.Специалист;
	КонецЕсли;
		
	// Движения по регистру ЗагруженностьСпециалистов
	Движения.ЗагруженностьСпециалистов.Записывать = Истина;
	Движение = Движения.ЗагруженностьСпециалистов.Добавить();
	Движение.Период          = Дата;
	Движение.Специалист      = СпециалистДляРегистра;
	Движение.Заявка          = Заявка;
	Движение.КоличествоРабот = 1;
	
	// Движения по регистру ОстаткиЗапчастей
	Движения.ОстаткиЗапчастей.Записывать = Истина;
	
	Для Каждого Строка Из Работы Цикл
		Если ТипЗнч(Строка.Номенклатура) = 
				Тип("СправочникСсылка.ТоварыНаСкладе") Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
				"ВЫБРАТЬ
				|	ОстаткиЗапчастейОстатки.КоличествоОстаток КАК Остаток
				|ИЗ
				|	РегистрНакопления.ОстаткиЗапчастей.Остатки(
				|		&Период,
				|		Запчасть = &Запчасть) КАК ОстаткиЗапчастейОстатки";
			
			Запрос.УстановитьПараметр("Период",   Дата);
			Запрос.УстановитьПараметр("Запчасть", Строка.Номенклатура);
			
			Результат = Запрос.Выполнить().Выбрать();
			ТекущийОстаток = 0;
			Если Результат.Следующий() Тогда
				ТекущийОстаток = Результат.Остаток;
			КонецЕсли;
			
			Если ТекущийОстаток < Строка.Количество Тогда
				Сообщение = Новый СообщениеПользователю;
				Сообщение.Текст = "Недостаточно запчасти: " 
					+ Строка.Номенклатура 
					+ ". Есть: " + ТекущийОстаток 
					+ ", нужно: " + Строка.Количество;
				Сообщение.Сообщить();
				Отказ = Истина;
				Возврат;
			КонецЕсли;
			
			Движение = Движения.ОстаткиЗапчастей.Добавить();
			Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
			Движение.Период      = Дата;
			Движение.Запчасть    = Строка.Номенклатура;
			Движение.Количество  = Строка.Количество;
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры